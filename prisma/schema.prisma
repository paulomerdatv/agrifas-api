generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

// WAITING_PAYMENT removido.
enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  ANSWERED
  CONCLUDED
}

enum TicketMessageSender {
  USER
  ADMIN
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum SecurityCodePurpose {
  PASSWORD_RESET
  TWO_FACTOR_EMAIL
}

enum WinnerDeliveryStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  steamId      String?   @unique
  steamAvatar  String?
  provider     String?
  twoFactorEnabled Boolean   @default(false)
  twoFactorMethod  String?
  twoFactorEmailVerifiedAt DateTime?
  refCode      String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  isBlocked    Boolean   @default(false)
  blockedAt    DateTime?
  blockedReason String?
  blockedByAdminId String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders         Order[]
  supportTickets SupportTicket[]
  winners        Winner[]
  securityCodes  UserSecurityCode[]
  securityEvents SecurityEvent[]
}

model UserSecurityCode {
  id         String              @id @default(uuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    SecurityCodePurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

model Raffle {
  id             String       @id @default(uuid())
  title          String
  description    String
  image          String
  pricePerTicket Float
  totalTickets   Int
  soldTickets    Int          @default(0)
  estimatedValue Float
  status         RaffleStatus @default(DRAFT)
  publishAt      DateTime?
  endAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  orders Order[]
  winner Winner?
  featuredInHomeConfigs HomeConfig[] @relation("HomeConfigFeaturedRaffle")
  featuredInCampaigns Campaign[] @relation("CampaignFeaturedRaffle")
}

model HomeConfig {
  id                  String   @id @default("default")
  heroTitle           String
  heroSubtitle        String
  heroButtonText      String
  heroButtonLink      String
  topNoticeText       String?
  promoTitle          String
  promoSubtitle       String
  promoButtonText     String
  promoButtonLink     String
  featuredRaffleId    String?
  heroBackgroundImage String?
  promoImage          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  featuredRaffle Raffle? @relation("HomeConfigFeaturedRaffle", fields: [featuredRaffleId], references: [id], onDelete: SetNull)

  @@index([featuredRaffleId])
}

model Campaign {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  description      String?
  active           Boolean  @default(false)
  startsAt         DateTime?
  endsAt           DateTime?
  bannerTitle      String?
  bannerSubtitle   String?
  bannerButtonText String?
  bannerButtonLink String?
  couponCode       String?
  featuredRaffleId String?
  priority         Int      @default(0)
  campaignType     String?
  imageUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featuredRaffle Raffle? @relation("CampaignFeaturedRaffle", fields: [featuredRaffleId], references: [id], onDelete: SetNull)

  @@index([active, priority, createdAt])
  @@index([startsAt, endsAt])
  @@index([featuredRaffleId])
}

model Order {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  raffleId String
  raffle   Raffle @relation(fields: [raffleId], references: [id])

  selectedTickets Int[]
  totalAmount     Float
  status          OrderStatus @default(PENDING)

  // Campos de Integração
  provider               String  @default("INFINITEPAY")
  orderNsu               String  @unique
  providerTransactionNsu String?
  receiptUrl             String?
  paymentMethod          String? @default("PIX")
  customerFullName       String?
  customerEmail          String?
  customerWhatsapp       String?
  customerTradeLink      String?
  customerCpfCnpj        String?
  refCode                String?
  utmSource              String?
  utmMedium              String?
  utmCampaign            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  winner               Winner?
  couponId             String?
  coupon               Coupon? @relation(fields: [couponId], references: [id])
  couponCode           String?
  couponDiscountAmount Float   @default(0)
  subtotalAmount       Float?
}

model Coupon {
  id         String     @id @default(uuid())
  code       String     @unique
  type       CouponType
  value      Float
  active     Boolean    @default(true)
  usageLimit Int?
  usedCount  Int        @default(0)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  orders Order[]
}

model SupportTicket {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  reason      String
  title       String
  status      SupportTicketStatus @default(OPEN)
  concludedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  messages SupportTicketMessage[]
}

model SupportTicketMessage {
  id        String              @id @default(uuid())
  ticketId  String
  ticket    SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    TicketMessageSender
  message   String
  createdAt DateTime            @default(now())
}

model Winner {
  id             String   @id @default(uuid())
  raffleId       String   @unique
  raffle         Raffle   @relation(fields: [raffleId], references: [id])
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  ticketNumber   Int
  drawnAt        DateTime @default(now())
  drawnByAdminId String?
  deliveryStatus WinnerDeliveryStatus @default(PENDING)
  deliveryNotes  String?
  deliveredAt    DateTime?
}

model WebhookEvent {
  id                String                  @id @default(uuid())
  provider          String
  eventType         String?
  payload           Json
  processingStatus  WebhookProcessingStatus @default(RECEIVED)
  errorMessage      String?
  orderNsu          String?
  createdAt         DateTime                @default(now())
  processedAt       DateTime?
  reprocessCount    Int                     @default(0)
  lastReprocessedAt DateTime?

  @@index([provider, processingStatus, createdAt])
  @@index([orderNsu])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?
  route     String?
  eventType String
  severity  String   @default("WARNING")
  context   Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}
