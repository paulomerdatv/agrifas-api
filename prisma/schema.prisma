generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

// WAITING_PAYMENT removido.
enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  ANSWERED
  CONCLUDED
}

enum TicketMessageSender {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  supportTickets SupportTicket[]
  winners      Winner[]
}

model Raffle {
  id             String       @id @default(uuid())
  title          String
  description    String
  image          String
  pricePerTicket Float
  totalTickets   Int
  soldTickets    Int          @default(0)
  estimatedValue Float
  status         RaffleStatus @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  orders         Order[]
  winner         Winner?
}

model Order {
  id                     String      @id @default(uuid())
  userId                 String
  user                   User        @relation(fields: [userId], references: [id])
  raffleId               String
  raffle                 Raffle      @relation(fields: [raffleId], references: [id])
  
  selectedTickets        Int[]
  totalAmount            Float
  status                 OrderStatus @default(PENDING)
  
  // Campos de Integração
  provider               String      @default("INFINITEPAY")
  orderNsu               String      @unique
  providerTransactionNsu String?     
  receiptUrl             String?     
  paymentMethod          String?     @default("PIX")
  customerFullName       String?
  customerEmail          String?
  customerWhatsapp       String?
  customerTradeLink      String?
  customerCpfCnpj        String?

  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  winner                 Winner?
}

model SupportTicket {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  reason      String
  title       String
  status      SupportTicketStatus @default(OPEN)
  concludedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  messages    SupportTicketMessage[]
}

model SupportTicketMessage {
  id        String              @id @default(uuid())
  ticketId  String
  ticket    SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    TicketMessageSender
  message   String
  createdAt DateTime            @default(now())
}

model Winner {
  id            String   @id @default(uuid())
  raffleId      String   @unique
  raffle        Raffle   @relation(fields: [raffleId], references: [id])
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  ticketNumber  Int
  drawnAt       DateTime @default(now())
  drawnByAdminId String?
}
